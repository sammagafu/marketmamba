# Telegram Bot Configuration
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_BOT_USERNAME=market_mamba_bot
# Bot numeric ID — only for OIDC popup login (requires Web Login URLs in BotFather)
# TELEGRAM_BOT_CLIENT_ID=8040019896
# Allowed URL host — register https://... in @BotFather → Web Login
TELEGRAM_LOGIN_DOMAIN=marketmamba.kkooapp.co.tz
PUBLIC_SITE_URL=https://marketmamba.kkooapp.co.tz

# Automatic SSL (Let's Encrypt via Caddy on docker compose up)
# If omitted, ADMIN_EMAIL is used as fallback inside the Caddy container
SSL_EMAIL=magafu317@gmail.com
# Local dev without TLS: ENABLE_SSL=false and APP_ENV=development
# ENABLE_SSL=true
# Optional override; defaults to TELEGRAM_LOGIN_DOMAIN
# SSL_DOMAIN=marketmamba.kkooapp.co.tz
TELEGRAM_ALLOWED_USER_IDS=5311857635
TELEGRAM_ADMIN_USER_IDS=5311857635

# Database Configuration
DATABASE_URL=postgres://forexbot:forexbot_password_change_me@localhost:5432/forexbot?sslmode=disable

# Broker Configuration (mock demo | oanda practice/live via dashboard)
BROKER_PROVIDER=mock

# Risk Management Settings
MAX_RISK_PER_TRADE=0.005
MAX_DAILY_LOSS=0.02
MAX_OPEN_TRADES=2
MAX_TRADES_PER_DAY=10
RISK_REWARD_RATIO=1.0

# Application Settings
APP_ENV=development
PORT=8080

# Web dashboard (https://marketmamba.kkooapp.co.tz)
HTTP_PORT=8090
ENABLE_WEB=true
WEB_API_KEY=change_me_to_a_long_random_secret
WEB_SESSION_SECRET=change_me_another_long_random_secret
# Web login session length (days) — default 365
WEB_SESSION_TTL_DAYS=365

# Broadcast trade signals to subscribed Telegram users
SIGNAL_BROADCAST_ENABLED=true
SIGNAL_BROADCAST_INTERVAL_SEC=300
SIGNAL_BROADCAST_SYMBOL=EURUSD
# Comma-separated pairs for signals + auto-monitor (broadcast + /autostart)
SIGNAL_BROADCAST_SYMBOLS=EURUSD,BTCUSD
# Minimum signal strength 0–1 (same threshold as auto-trading filters)
SIGNAL_MIN_STRENGTH=0.7

# Real-time sniper decision support (live prices: Frankfurter + CoinGecko; optional Twelve Data)
DECISION_ENABLED=true
DECISION_INTERVAL_SEC=60
SNIPER_MIN_CONFIDENCE=0.75
SNIPER_COOLDOWN_MIN=45
# both | advisory | auto
DECISION_MODE=both
# Optional: faster warm-up + bid/ask from https://twelvedata.com
MARKET_DATA_API_KEY=
CORS_ORIGINS=https://marketmamba.kkooapp.co.tz
BROKER_ENCRYPTION_KEY=change_me_32_chars_minimum_secret
# Comma-separated brand IDs shown in connect wizard (empty = all)
# Live traders: MT brokers via MetaAPI bridge (any_mt = any MT4/MT5 server)
ENABLED_BROKER_BRANDS=mock,deriv,exness,tickmill,any_mt
# Optional: your MetaAPI token — clients only enter MT login, password, server
METAAPI_SHARED_TOKEN=

# Public bot & subscriptions
PUBLIC_MODE=true
# 5-day trial, then 10 USDT/month via Binance (Mini App)
SUBSCRIPTION_REQUIRED=true
FREE_TRIAL_DAYS=5
SUBSCRIPTION_PRICE_USDT=10
SUBSCRIPTION_DAYS=30
# Binance Pay merchant API (optional — from Binance Merchant portal)
BINANCE_PAY_API_KEY=
BINANCE_PAY_SECRET=
BINANCE_PAY_CERT_SN=
# Or manual USDT to your Binance account:
BINANCE_PAY_UID=
BINANCE_PAY_NETWORK=TRC20
MINI_APP_URL=https://marketmamba.kkooapp.co.tz
# Production: set true so /autostart needs admin /approveauto
AUTO_TRADE_REQUIRES_APPROVAL=false
SUBSCRIPTION_CONTACT=5-day trial then 10 USDT/month via Binance in the Mini App.

# Web admin (set on VPS only — run: docker compose -p marketmamba exec app ./server seed-admin)
ADMIN_EMAIL=magafu317@gmail.com
ADMIN_PASSWORD=change_me_min_8_chars
ADMIN_TELEGRAM_ID=5311857635
