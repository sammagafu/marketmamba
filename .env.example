# Telegram Bot Configuration
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_ALLOWED_USER_IDS=123456789,987654321

# Database Configuration
DATABASE_URL=postgres://forexbot:forexbot_password_change_me@localhost:5432/forexbot?sslmode=disable

# Broker Configuration
BROKER_PROVIDER=mock

# Risk Management Settings
MAX_RISK_PER_TRADE=0.005
MAX_DAILY_LOSS=0.02
MAX_OPEN_TRADES=2
MAX_TRADES_PER_DAY=10
RISK_REWARD_RATIO=1.0

# Application Settings
APP_ENV=development
PORT=8080

# Web dashboard (https://marketmamba.kkooapp.co.tz)
HTTP_PORT=8090
ENABLE_WEB=true
WEB_API_KEY=change_me_to_a_long_random_secret
CORS_ORIGINS=https://marketmamba.kkooapp.co.tz
BROKER_ENCRYPTION_KEY=change_me_32_chars_minimum_secret
