# HTTPS config — use after certbot certificates exist.
# /etc/nginx/sites-available/marketmamba.kkooapp.co.tz

# Redirect HTTP → HTTPS
server {
    listen 80;
    listen [::]:80;
    server_name marketmamba.kkooapp.co.tz;
    return 301 https://$host$request_uri;
}

server {
    listen 443 ssl http2;
    listen [::]:443 ssl http2;
    server_name marketmamba.kkooapp.co.tz;

    ssl_certificate /etc/letsencrypt/live/marketmamba.kkooapp.co.tz/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/marketmamba.kkooapp.co.tz/privkey.pem;
    include /etc/letsencrypt/options-ssl-nginx.conf;
    ssl_dhparam /etc/letsencrypt/ssl-dhparams.pem;

    # Required for Telegram Login popup (oauth.telegram.org)
    add_header Cross-Origin-Opener-Policy "same-origin-allow-popups" always;

    location / {
        proxy_pass http://127.0.0.1:8090;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto https;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";
        proxy_connect_timeout 60s;
        proxy_read_timeout 60s;
    }
}
